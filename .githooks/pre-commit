#!/usr/bin/env bash
set -euo pipefail

if [[ "${SKIP_AUTO_VERSION_BUMP:-0}" == "1" ]]; then
  exit 0
fi

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

NEW_VERSION="$(python scripts/bump_pyproject_version.py)"
git add pyproject.toml
echo "[pre-commit] bumped pyproject version to ${NEW_VERSION}."
